{
  "plugin": "SquadCreationBlocker",
  "enabled": true,
  "blockDuration": 15,
  "broadcastMode": false,
  "allowDefaultSquadNames": true,
  "enableRateLimiting": true,
  "rateLimitingScope": "entireMatch",
  "warningThreshold": 2,
